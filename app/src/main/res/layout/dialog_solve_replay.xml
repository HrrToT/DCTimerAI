<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/replay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/iv_replay_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/fl_cube"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="7" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_move_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:lineSpacingMultiplier="1.15"
                android:minHeight="44dp"
                android:textColor="#E0E0E0"
                android:textSize="16sp" />

            <View
                android:id="@+id/v_info_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#33FFFFFF" />

            <TextView
                android:id="@+id/tv_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="center"
                android:lineSpacingMultiplier="1.2"
                android:textColor="#BDBDBD"
                android:textSize="13sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
        </LinearLayout>

        <com.dctimer.view.SolveReplayRenderer
            android:id="@+id/sparkline"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:paddingBottom="4dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="⏮"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="⏪"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_play"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1.2"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="▶"
            android:textAllCaps="false"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="⏩"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_end"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginLeft="4dp"
            android:layout_weight="1"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="⏭"
            android:textAllCaps="false"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_speed"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_marginLeft="6dp"
            android:layout_weight="1.8"
            android:minWidth="0dp"
            android:padding="0dp"
            android:text="Speed: 1x"
            android:textAllCaps="false"
            android:textSize="12sp" />

            <Button
                android:id="@+id/btn_close"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginLeft="6dp"
                android:layout_weight="1.4"
                android:minWidth="0dp"
                android:text="@string/btn_close"
                android:textAllCaps="false"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>

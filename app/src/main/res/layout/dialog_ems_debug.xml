<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#FF1A1A1A">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMS 调试"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button android:id="@+id/btn_e"   android:layout_width="48dp" android:layout_height="40dp"
            android:text="E" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" />
        <Button android:id="@+id/btn_ei"  android:layout_width="48dp" android:layout_height="40dp"
            android:text="E'" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" android:layout_marginLeft="4dp" />
        <Button android:id="@+id/btn_m"   android:layout_width="48dp" android:layout_height="40dp"
            android:text="M" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" android:layout_marginLeft="4dp" />
        <Button android:id="@+id/btn_mi"  android:layout_width="48dp" android:layout_height="40dp"
            android:text="M'" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" android:layout_marginLeft="4dp" />
        <Button android:id="@+id/btn_s"   android:layout_width="48dp" android:layout_height="40dp"
            android:text="S" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" android:layout_marginLeft="4dp" />
        <Button android:id="@+id/btn_si"  android:layout_width="48dp" android:layout_height="40dp"
            android:text="S'" android:textAllCaps="false" android:minWidth="0dp" android:padding="0dp" android:layout_marginLeft="4dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_sequence"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="R U R' E M' S2..."
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:background="#333333"
            android:padding="8dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btn_exec"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="执行"
            android:layout_marginLeft="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button android:id="@+id/btn_prev" android:layout_width="56dp" android:layout_height="36dp"
            android:text="◀" android:minWidth="0dp" android:padding="0dp" />
        <TextView
            android:id="@+id/tv_step"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:fontFamily="monospace" />
        <Button android:id="@+id/btn_next" android:layout_width="56dp" android:layout_height="36dp"
            android:text="▶" android:minWidth="0dp" android:padding="0dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#BDBDBD"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.1" />
    </ScrollView>

    <Button
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="@string/btn_close"
        android:layout_marginTop="8dp" />
</LinearLayout>
